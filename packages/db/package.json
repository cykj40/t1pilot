{
  "name": "@t1copilot/db",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:generate:neon": "pnpm build && drizzle-kit generate --config=drizzle.neon.config.ts",
    "db:generate:turso": "drizzle-kit generate --config=drizzle.turso.config.ts",
    "db:migrate:neon": "drizzle-kit migrate --config=drizzle.neon.config.ts",
    "db:migrate:turso": "drizzle-kit migrate --config=drizzle.turso.config.ts",
    "db:studio:neon": "drizzle-kit studio --config=drizzle.neon.config.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "dotenv": "^16.0.0",
    "@neondatabase/serverless": "^0.10.4",
    "@paralleldrive/cuid2": "^2.2.2",
    "@t1copilot/types": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.3"
  }
}
